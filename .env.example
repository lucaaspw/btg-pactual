# Copie para .env.local e preencha. Não faça commit do .env.local.

# Obrigatório para páginas que leem ofertas e para POST /api/ofertas
# URL do WordPress sem barra final
NEXT_PUBLIC_WP_URL=https://seu-wordpress.com

# Opcional: e-mail nos CTAs de concierge (Partners / Ultrablue)
# NEXT_PUBLIC_PARTNERS_CONCIERGE_EMAIL=concierge@exemplo.com

# Obrigatório apenas para publicar ofertas via POST /api/ofertas (Application Password)
# WP_API_USER=
# WP_API_APP_PASSWORD=
#BTG_USERNAME=
#BTG_PASSWORD=